generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  name      String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trips     Trip[]
  feedback  UserFeedback[]
  analytics AnalyticsEvent[]
}

model Trip {
  id                  String              @id @default(cuid())
  userId              String?
  user                User?               @relation(fields: [userId], references: [id])
  title               String
  cityId              String?
  month               String?
  budgetLevel         String?
  goal                String?
  computedScore       Int?
  notes               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  preferenceProfileId String?
  preferenceProfile   PreferenceProfile?  @relation(fields: [preferenceProfileId], references: [id])
  recommendations     Recommendation[]
  routes              ItineraryRoute[]
}

model PreferenceProfile {
  id        String   @id @default(cuid())
  rawInput  String
  intent    Json
  createdAt DateTime @default(now())
  trips     Trip[]
}

model City {
  id                    String         @id
  name                  String
  country               String
  continent             String         @default("Europe")
  lat                   Float          @default(0)
  lng                   Float          @default(0)
  types                 String[]
  baseCostPerPerson     Int
  averageDailyCost      Int
  socialDensityScore    Int
  nightlifeScore        Int
  historyScore          Int
  foodCultureScore      Int
  mobilityScore         Int
  seaAccess             Boolean
  crowdPressureByMonth  Json
  seasonalityByMonth    Json
  bestNeighborhoods     String[]
  riskFlags             String[]
  nationalityMixContext String
  notes                 String
  sourceSummary         Json?
  confidenceScore       Int            @default(50)
  updatedAt             DateTime       @updatedAt
  neighborhoods         Neighborhood[]
  places                Place[]
  events                Event[]
  snapshots             RawSnapshot[]
  priceSnapshots        PriceSnapshot[]
  providerSignals       ProviderSignal[]
}

model Neighborhood {
  id      String @id @default(cuid())
  cityId  String
  city    City   @relation(fields: [cityId], references: [id])
  name    String
  notes   String?
  score   Int?
}

model Place {
  id                      String            @id
  name                    String
  type                    String
  cityId                  String
  city                    City              @relation(fields: [cityId], references: [id])
  neighborhood            String
  ambienceTags            String[]
  featureTags             String[]
  priceLevel              Int
  socialAmbienceScore     Int
  evidenceConfidenceScore Int
  businessConfirmed       Boolean           @default(false)
  goodFor                 String[]
  notes                   String
  images                  PlaceImage[]
  aiTags                  PlaceAiTag[]
  businessProfiles        BusinessProfile[]
}

model PlaceFeature {
  id          String @id @default(cuid())
  key         String @unique
  label       String
  description String?
}

model PlaceImage {
  id                String   @id @default(cuid())
  placeId           String?
  place             Place?   @relation(fields: [placeId], references: [id])
  businessProfileId String?
  url               String
  storagePath       String?
  bucket            String?
  category          String
  analysis          Json?
  consentConfirmed  Boolean  @default(false)
  createdAt         DateTime @default(now())
}

model PlaceAiTag {
  id         String   @id @default(cuid())
  placeId    String
  place      Place    @relation(fields: [placeId], references: [id])
  tags       Json
  confidence Json
  provider   String   @default("local")
  createdAt  DateTime @default(now())
}

model BusinessClaim {
  id            String   @id @default(cuid())
  placeId       String?
  businessName  String
  claimantEmail String
  status        String   @default("pending")
  createdAt     DateTime @default(now())
}

model BusinessProfile {
  id        String   @id @default(cuid())
  placeId   String?
  place     Place?   @relation(fields: [placeId], references: [id])
  profile   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id       String @id
  name     String
  category String
  cityId   String
  city     City   @relation(fields: [cityId], references: [id])
  tags     String[]
  notes    String
}

model Recommendation {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id])
  type      String
  targetId  String
  score     Int
  reason    String
  createdAt DateTime @default(now())
}

model ItineraryRoute {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id])
  route     Json
  createdAt DateTime @default(now())
}

model UserFeedback {
  id                 String   @id @default(cuid())
  userId             String?
  user               User?    @relation(fields: [userId], references: [id])
  targetType         String
  targetId           String
  rating             Int
  matchedExpectation Boolean? 
  crowdAccuracy      Int?
  socialAccuracy     Int?
  budgetAccuracy     Int?
  notes              String?
  createdAt          DateTime @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  eventName String
  cityId    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([eventName])
  @@index([cityId])
}

model ProviderStatus {
  id            String   @id @default(cuid())
  provider      String   @unique
  status        String
  configured    Boolean  @default(false)
  requiresKey   Boolean  @default(false)
  lastSuccessAt DateTime?
  lastErrorAt   DateTime?
  lastError     String?
  updatedAt     DateTime @updatedAt
}

model RawSnapshot {
  id        String   @id @default(cuid())
  source    String
  endpoint  String?
  status    String
  cityId    String?
  city      City?    @relation(fields: [cityId], references: [id])
  payload   Json?
  error     String?
  fetchedAt DateTime @default(now())

  @@index([source])
  @@index([cityId])
}

model ProviderSignal {
  id              String   @id @default(cuid())
  cityId          String?
  city            City?    @relation(fields: [cityId], references: [id])
  provider        String
  signalType      String
  score           Int?
  confidenceScore Int      @default(50)
  sourceLabel     String   @default("fallback")
  payload         Json?
  createdAt       DateTime @default(now())

  @@index([provider])
  @@index([signalType])
}

model PriceSnapshot {
  id              String   @id @default(cuid())
  cityId          String?
  city            City?    @relation(fields: [cityId], references: [id])
  source          String
  priceType       String
  value           Float?
  currency        String   @default("EUR")
  periodStart     DateTime?
  periodEnd       DateTime?
  confidenceScore Int      @default(50)
  payload         Json?
  createdAt       DateTime @default(now())

  @@index([cityId])
  @@index([priceType])
}

model IngestionRun {
  id            String   @id @default(cuid())
  source        String
  jobType       String
  status        String
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  rowsProcessed Int      @default(0)
  error         String?
  metadata      Json?
}

model CostModelRun {
  id        String   @id @default(cuid())
  input     Json
  output    Json
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
}
