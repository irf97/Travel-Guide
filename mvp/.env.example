# Public-safe template only.
# Copy this file to .env.local locally, or add the real values in Vercel Project Settings → Environment Variables.
# Never commit real API keys to GitHub.

# OpenAI - server only. Do NOT prefix with NEXT_PUBLIC.
OPENAI_API_KEY=

# Supabase client values.
# NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY may be visible in browser bundles.
# They are okay to expose only with proper Supabase Row Level Security policies.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role - server only. Never expose this client-side.
SUPABASE_SERVICE_ROLE_KEY=

# Database connection string - server only.
DATABASE_URL=

# Optional maps/place providers - server only unless the provider explicitly requires a browser key.
MAPS_API_KEY=
PLACES_API_KEY=

# App config.
NEXT_PUBLIC_APP_URL=http://localhost:3000
