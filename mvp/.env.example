# Public-safe template only.
# Copy this file to .env.local locally, or add real values in Vercel Project Settings → Environment Variables.
# Never commit real API keys to GitHub.

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database connection string - server only.
# If missing, DB routes/adapters must fall back safely.
DATABASE_URL=

# OpenAI - server only. Do NOT prefix with NEXT_PUBLIC.
# Paid AI usage is gated; routes return local fallback unless explicitly requested and this key exists.
OPENAI_API_KEY=

# Supabase client values.
# NEXT_PUBLIC_* values may be visible in browser bundles and require proper RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role - server only. Never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=place-images

# Cron/security
CRON_SECRET=

# Open-data foundation providers
OPEN_METEO_BASE_URL=https://api.open-meteo.com
OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
PHOTON_BASE_URL=https://photon.komoot.io
WORLDBANK_BASE_URL=https://api.worldbank.org/v2
OECD_BASE_URL=https://sdmx.oecd.org/public/rest
EUROSTAT_BASE_URL=https://ec.europa.eu/eurostat/api/dissemination
WIKIDATA_SPARQL_URL=https://query.wikidata.org/sparql
OWID_BASE_URL=https://ourworldindata.org/grapher
GDELT_DOC_BASE_URL=https://api.gdeltproject.org/api/v2/doc/doc
GDELT_CONTEXT_BASE_URL=https://api.gdeltproject.org/api/v2/context/context
GDELT_GEO_BASE_URL=https://api.gdeltproject.org/api/v2/geo/geo

# Bulk POI providers / workers
OVERTURE_RELEASE=latest
OVERTURE_PLACES_S3_PATH=
FSQ_OS_PLACES_TOKEN=
FSQ_OS_PLACES_CATALOG_URI=
FSQ_OS_PLACES_RELEASE=

# Commercial gap-fillers
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
DUFFEL_ACCESS_TOKEN=
LITEAPI_KEY=
TICKETMASTER_API_KEY=
DATA_APPEAL_API_KEY=
DATA_APPEAL_BASE_URL=

# Legacy optional maps/place providers
MAPS_API_KEY=
PLACES_API_KEY=
