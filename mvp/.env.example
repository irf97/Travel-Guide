# Public-safe template only.
# Copy this file to .env.local locally, or add real values in Vercel Project Settings → Environment Variables.
# Never commit real API keys to GitHub.

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Storage / infra
DATABASE_URL=
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
CRON_SECRET=

# OpenAI - server only. Do NOT prefix with NEXT_PUBLIC.
# Paid AI usage is gated; routes return local fallback unless explicitly requested and this key exists.
OPENAI_API_KEY=

# Self-hosted / managed Supabase, only if used.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=place-images

# Bulk datasets: no provider keys required except HF token for newer FSQ OS Places releases.
OVERTURE_RELEASE=2026-04-15.0
OVERTURE_S3_BUCKET=s3://overturemaps-us-west-2

HF_TOKEN=
FSQ_OS_PLACES_DATASET=foursquare/fsq-os-places
FSQ_OS_PLACES_RELEASE=2026-04-14

GDELT_DOC_API_BASE=https://api.gdeltproject.org/api/v2/doc/doc
GDELT_EVENTS_BASE=http://data.gdeltproject.org/gdeltv2

EUROSTAT_API_BASE=https://ec.europa.eu/eurostat/api/dissemination/statistics/1.0/data
WORLDBANK_API_BASE=https://api.worldbank.org/v2
OECD_SDMX_BASE=https://sdmx.oecd.org/public/rest
WIKIDATA_SPARQL=https://query.wikidata.org/sparql
GEOFABRIK_BASE=https://download.geofabrik.de

# Live APIs: no keys, but rate-limited. Cache aggressively.
OPEN_METEO_BASE=https://api.open-meteo.com/v1
OPEN_METEO_ARCHIVE_BASE=https://archive-api.open-meteo.com/v1
OVERPASS_URL=https://overpass-api.de/api/interpreter
NOMINATIM_URL=https://nominatim.openstreetmap.org
PHOTON_URL=https://photon.komoot.io

# Commercial slots with no open replacement.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test
DUFFEL_ACCESS_TOKEN=
LITEAPI_KEY=

# Optional ticket/inventory/commercial tourism enrichment.
TICKETMASTER_API_KEY=
DATA_APPEAL_API_KEY=
DATA_APPEAL_BASE_URL=

# Legacy compatibility aliases. Prefer the names above for new code.
OPEN_METEO_BASE_URL=https://api.open-meteo.com
OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
WORLDBANK_BASE_URL=https://api.worldbank.org/v2
OECD_BASE_URL=https://sdmx.oecd.org/public/rest
EUROSTAT_BASE_URL=https://ec.europa.eu/eurostat/api/dissemination
WIKIDATA_SPARQL_URL=https://query.wikidata.org/sparql
